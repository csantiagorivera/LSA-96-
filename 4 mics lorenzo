/*******************************************************************************
 * Macros
 ******************************************************************************/
#define PDM_PCM_ISR_PRIORITY        (2u)

#define PDM_CHANNEL_CH0             (0u)
#define PDM_CHANNEL_CH1             (1u)
#define PDM_CHANNEL_LEFT            (2u)
#define PDM_CHANNEL_RIGHT           (3u)

#define HW_FIFO_SIZE                (64u)
#define RX_FIFO_TRIG_LEVEL          (HW_FIFO_SIZE/2)
#define NUMBER_INTERRUPTS_FOR_FRAME (FRAME_SIZE/RX_FIFO_TRIG_LEVEL)
#define DIGITAL_BOOST_FACTOR        1.0f
#define AUIDO_BITS_PER_SAMPLE       16
#define SAMPLE_NORMALIZE(sample)    (((float)(sample)) / (float)(1 << (AUIDO_BITS_PER_SAMPLE - 1)))
#define OUTPUT_THRESHOLD_SCORE      (0.6f)
#define PDM_PCM_GAIN                (CY_PDM_PCM_SEL_GAIN_5DB)

/*******************************************************************************
 * Global Variables
 ******************************************************************************/
/* CH0 ping-pong buffers */
static int16_t audio_buffer0_ch0[FRAME_SIZE] = {0};
static int16_t audio_buffer1_ch0[FRAME_SIZE] = {0};
static int16_t* active_rx_buffer_ch0;
static int16_t* full_rx_buffer_ch0;

/* CH1 ping-pong buffers */
static int16_t audio_buffer0_ch1[FRAME_SIZE] = {0};
static int16_t audio_buffer1_ch1[FRAME_SIZE] = {0};
static int16_t* active_rx_buffer_ch1;
static int16_t* full_rx_buffer_ch1;

/* LEFT (CH2) ping-pong buffers */
static int16_t audio_buffer0_left[FRAME_SIZE] = {0};
static int16_t audio_buffer1_left[FRAME_SIZE] = {0};
static int16_t* active_rx_buffer_left;
static int16_t* full_rx_buffer_left;

/* RIGHT (CH3) ping-pong buffers */
static int16_t audio_buffer0_right[FRAME_SIZE] = {0};
static int16_t audio_buffer1_right[FRAME_SIZE] = {0};
static int16_t* active_rx_buffer_right;
static int16_t* full_rx_buffer_right;

/* IRQ configs */
static const cy_stc_sysint_t PDM_IRQ_cfg_ch0 =
    { .intrSrc = (IRQn_Type)CYBSP_PDM_CHANNEL_0_IRQ, .intrPriority = PDM_PCM_ISR_PRIORITY };
static const cy_stc_sysint_t PDM_IRQ_cfg_ch1 =
    { .intrSrc = (IRQn_Type)CYBSP_PDM_CHANNEL_1_IRQ, .intrPriority = PDM_PCM_ISR_PRIORITY };
static const cy_stc_sysint_t PDM_IRQ_cfg_left =
    { .intrSrc = (IRQn_Type)CYBSP_PDM_CHANNEL_2_IRQ, .intrPriority = PDM_PCM_ISR_PRIORITY };
static const cy_stc_sysint_t PDM_IRQ_cfg_right =
    { .intrSrc = (IRQn_Type)CYBSP_PDM_CHANNEL_3_IRQ, .intrPriority = PDM_PCM_ISR_PRIORITY };

/* Data ready flags */
static volatile bool pdm_pcm_flag_ch0;
static volatile bool pdm_pcm_flag_ch1;
static volatile bool pdm_pcm_flag_left;
static volatile bool pdm_pcm_flag_right;

/*******************************************************************************
 * Local Prototypes
 ******************************************************************************/
static void pdm_pcm_event_handler_ch0(void);
static void pdm_pcm_event_handler_ch1(void);
static void pdm_pcm_event_handler_left(void);
static void pdm_pcm_event_handler_right(void);

/*******************************************************************************
 * Function: pdm_init
 ******************************************************************************/
cy_rslt_t pdm_init(void)
{
    cy_rslt_t result;

    /* Init all ping-pong buffers */
    memset(audio_buffer0_ch0,    0, FRAME_SIZE*sizeof(int16_t));
    memset(audio_buffer1_ch0,    0, FRAME_SIZE*sizeof(int16_t));
    memset(audio_buffer0_ch1,    0, FRAME_SIZE*sizeof(int16_t));
    memset(audio_buffer1_ch1,    0, FRAME_SIZE*sizeof(int16_t));
    memset(audio_buffer0_left,   0, FRAME_SIZE*sizeof(int16_t));
    memset(audio_buffer1_left,   0, FRAME_SIZE*sizeof(int16_t));
    memset(audio_buffer0_right,  0, FRAME_SIZE*sizeof(int16_t));
    memset(audio_buffer1_right,  0, FRAME_SIZE*sizeof(int16_t));

    active_rx_buffer_ch0   = audio_buffer0_ch0;
    full_rx_buffer_ch0     = audio_buffer1_ch0;
    active_rx_buffer_ch1   = audio_buffer0_ch1;
    full_rx_buffer_ch1     = audio_buffer1_ch1;
    active_rx_buffer_left  = audio_buffer0_left;
    full_rx_buffer_left    = audio_buffer1_left;
    active_rx_buffer_right = audio_buffer0_right;
    full_rx_buffer_right   = audio_buffer1_right;

    /* Init PDM block */
    result = Cy_PDM_PCM_Init(CYBSP_PDM_HW, &CYBSP_PDM_config);
    if(CY_PDM_PCM_SUCCESS != result) return result;

    /* --- CH0 --- */
    Cy_PDM_PCM_Channel_Enable(CYBSP_PDM_HW, PDM_CHANNEL_CH0);
    Cy_PDM_PCM_Channel_Init(CYBSP_PDM_HW, &channel_0_config, (uint8_t)PDM_CHANNEL_CH0);
    Cy_PDM_PCM_SetGain(CYBSP_PDM_HW, PDM_CHANNEL_CH0, PDM_PCM_GAIN);
    Cy_PDM_PCM_Channel_ClearInterrupt(CYBSP_PDM_HW, PDM_CHANNEL_CH0, CY_PDM_PCM_INTR_MASK);
    Cy_PDM_PCM_Channel_SetInterruptMask(CYBSP_PDM_HW, PDM_CHANNEL_CH0, CY_PDM_PCM_INTR_MASK);
    result = Cy_SysInt_Init(&PDM_IRQ_cfg_ch0, &pdm_pcm_event_handler_ch0);
    if(CY_SYSINT_SUCCESS != result) return result;
    NVIC_ClearPendingIRQ(PDM_IRQ_cfg_ch0.intrSrc);
    NVIC_EnableIRQ(PDM_IRQ_cfg_ch0.intrSrc);

    /* --- CH1 --- */
    Cy_PDM_PCM_Channel_Enable(CYBSP_PDM_HW, PDM_CHANNEL_CH1);
    Cy_PDM_PCM_Channel_Init(CYBSP_PDM_HW, &channel_1_config, (uint8_t)PDM_CHANNEL_CH1);
    Cy_PDM_PCM_SetGain(CYBSP_PDM_HW, PDM_CHANNEL_CH1, PDM_PCM_GAIN);
    Cy_PDM_PCM_Channel_ClearInterrupt(CYBSP_PDM_HW, PDM_CHANNEL_CH1, CY_PDM_PCM_INTR_MASK);
    Cy_PDM_PCM_Channel_SetInterruptMask(CYBSP_PDM_HW, PDM_CHANNEL_CH1, CY_PDM_PCM_INTR_MASK);
    result = Cy_SysInt_Init(&PDM_IRQ_cfg_ch1, &pdm_pcm_event_handler_ch1);
    if(CY_SYSINT_SUCCESS != result) return result;
    NVIC_ClearPendingIRQ(PDM_IRQ_cfg_ch1.intrSrc);
    NVIC_EnableIRQ(PDM_IRQ_cfg_ch1.intrSrc);

    /* --- LEFT / CH2 --- */
    Cy_PDM_PCM_Channel_Enable(CYBSP_PDM_HW, PDM_CHANNEL_LEFT);
    Cy_PDM_PCM_Channel_Init(CYBSP_PDM_HW, &channel_2_config, (uint8_t)PDM_CHANNEL_LEFT);
    Cy_PDM_PCM_SetGain(CYBSP_PDM_HW, PDM_CHANNEL_LEFT, PDM_PCM_GAIN);
    Cy_PDM_PCM_Channel_ClearInterrupt(CYBSP_PDM_HW, PDM_CHANNEL_LEFT, CY_PDM_PCM_INTR_MASK);
    Cy_PDM_PCM_Channel_SetInterruptMask(CYBSP_PDM_HW, PDM_CHANNEL_LEFT, CY_PDM_PCM_INTR_MASK);
    result = Cy_SysInt_Init(&PDM_IRQ_cfg_left, &pdm_pcm_event_handler_left);
    if(CY_SYSINT_SUCCESS != result) return result;
    NVIC_ClearPendingIRQ(PDM_IRQ_cfg_left.intrSrc);
    NVIC_EnableIRQ(PDM_IRQ_cfg_left.intrSrc);

    /* --- RIGHT / CH3 --- */
    Cy_PDM_PCM_Channel_Enable(CYBSP_PDM_HW, PDM_CHANNEL_RIGHT);
    Cy_PDM_PCM_Channel_Init(CYBSP_PDM_HW, &channel_3_config, (uint8_t)PDM_CHANNEL_RIGHT);
    Cy_PDM_PCM_SetGain(CYBSP_PDM_HW, PDM_CHANNEL_RIGHT, PDM_PCM_GAIN);
    Cy_PDM_PCM_Channel_ClearInterrupt(CYBSP_PDM_HW, PDM_CHANNEL_RIGHT, CY_PDM_PCM_INTR_MASK);
    Cy_PDM_PCM_Channel_SetInterruptMask(CYBSP_PDM_HW, PDM_CHANNEL_RIGHT, CY_PDM_PCM_INTR_MASK);
    result = Cy_SysInt_Init(&PDM_IRQ_cfg_right, &pdm_pcm_event_handler_right);
    if(CY_SYSINT_SUCCESS != result) return result;
    NVIC_ClearPendingIRQ(PDM_IRQ_cfg_right.intrSrc);
    NVIC_EnableIRQ(PDM_IRQ_cfg_right.intrSrc);

    /* Reset flags */
    pdm_pcm_flag_ch0   = false;
    pdm_pcm_flag_ch1   = false;
    pdm_pcm_flag_left  = false;
    pdm_pcm_flag_right = false;

    /* Activate all 4 channels */
    Cy_PDM_PCM_Activate_Channel(CYBSP_PDM_HW, PDM_CHANNEL_CH0);
    Cy_PDM_PCM_Activate_Channel(CYBSP_PDM_HW, PDM_CHANNEL_CH1);
    Cy_PDM_PCM_Activate_Channel(CYBSP_PDM_HW, PDM_CHANNEL_LEFT);
    Cy_PDM_PCM_Activate_Channel(CYBSP_PDM_HW, PDM_CHANNEL_RIGHT);

    return CY_RSLT_SUCCESS;
}

/*******************************************************************************
 * ISR Handlers — same pattern x4
 ******************************************************************************/
#define PDM_ISR_BODY(CH, active_buf, full_buf, flag)                          \
{                                                                              \
    static uint16_t frame_counter = 0;                                        \
    uint32_t intr_status = Cy_PDM_PCM_Channel_GetInterruptStatusMasked(       \
                               CYBSP_PDM_HW, CH);                             \
    if(CY_PDM_PCM_INTR_RX_TRIGGER & intr_status)                              \
    {                                                                          \
        for(uint32_t i=0; i < RX_FIFO_TRIG_LEVEL; i++)                        \
            active_buf[frame_counter * RX_FIFO_TRIG_LEVEL + i] =              \
                (int16_t)Cy_PDM_PCM_Channel_ReadFifo(CYBSP_PDM_HW, CH);      \
        Cy_PDM_PCM_Channel_ClearInterrupt(CYBSP_PDM_HW, CH,                   \
                                          CY_PDM_PCM_INTR_RX_TRIGGER);        \
        frame_counter++;                                                       \
    }                                                                          \
    if(NUMBER_INTERRUPTS_FOR_FRAME <= frame_counter)                           \
    {                                                                          \
        int16_t* tmp = active_buf; active_buf = full_buf; full_buf = tmp;     \
        flag = true; frame_counter = 0;                                        \
    }                                                                          \
    if((CY_PDM_PCM_INTR_RX_FIR_OVERFLOW | CY_PDM_PCM_INTR_RX_OVERFLOW |      \
        CY_PDM_PCM_INTR_RX_IF_OVERFLOW  | CY_PDM_PCM_INTR_RX_UNDERFLOW)      \
        & intr_status)                                                         \
        Cy_PDM_PCM_Channel_ClearInterrupt(CYBSP_PDM_HW, CH,                   \
                                          CY_PDM_PCM_INTR_MASK);              \
}

static void pdm_pcm_event_handler_ch0(void)
    PDM_ISR_BODY(PDM_CHANNEL_CH0, active_rx_buffer_ch0, full_rx_buffer_ch0, pdm_pcm_flag_ch0)

static void pdm_pcm_event_handler_ch1(void)
    PDM_ISR_BODY(PDM_CHANNEL_CH1, active_rx_buffer_ch1, full_rx_buffer_ch1, pdm_pcm_flag_ch1)

static void pdm_pcm_event_handler_left(void)
    PDM_ISR_BODY(PDM_CHANNEL_LEFT, active_rx_buffer_left, full_rx_buffer_left, pdm_pcm_flag_left)

static void pdm_pcm_event_handler_right(void)
    PDM_ISR_BODY(PDM_CHANNEL_RIGHT, active_rx_buffer_right, full_rx_buffer_right, pdm_pcm_flag_right)

/*******************************************************************************
 * Function: pdm_data_process
 ******************************************************************************/
cy_rslt_t pdm_data_process(void)
{
    cy_rslt_t result = CY_RSLT_SUCCESS;
    int16_t best_label = 0;
    float max_score = 0.0f;
    float label_scores[IMAI_DATA_OUT_COUNT];
    char *label_text[] = IMAI_DATA_OUT_SYMBOLS;

    /* Wait for all 4 channels */
    if (!pdm_pcm_flag_ch0 || !pdm_pcm_flag_ch1 ||
        !pdm_pcm_flag_left || !pdm_pcm_flag_right)
        return PDM_PCM_DATA_NOT_READY;

    pdm_pcm_flag_ch0   = false;
    pdm_pcm_flag_ch1   = false;
    pdm_pcm_flag_left  = false;
    pdm_pcm_flag_right = false;

    printf("\033[H\n");
#ifdef COMPONENT_CM33
    printf("DEEPCRAFT Deploy Audio - CM33 - 4 MIC\r\n\n");
#else
    printf("DEEPCRAFT Deploy Audio - CM55 - 4 MIC\r\n\n");
#endif

    for (uint32_t index = 0; index < FRAME_SIZE; index++)
    {
        float s0 = SAMPLE_NORMALIZE(full_rx_buffer_ch0[index])  * DIGITAL_BOOST_FACTOR;
        float s1 = SAMPLE_NORMALIZE(full_rx_buffer_ch1[index])  * DIGITAL_BOOST_FACTOR;
        float s2 = SAMPLE_NORMALIZE(full_rx_buffer_left[index]) * DIGITAL_BOOST_FACTOR;
        float s3 = SAMPLE_NORMALIZE(full_rx_buffer_right[index])* DIGITAL_BOOST_FACTOR;

        /* Clamp to [-1, 1] */
        s0 = s0 >  1.0f ?  1.0f : s0 < -1.0f ? -1.0f : s0;
        s1 = s1 >  1.0f ?  1.0f : s1 < -1.0f ? -1.0f : s1;
        s2 = s2 >  1.0f ?  1.0f : s2 < -1.0f ? -1.0f : s2;
        s3 = s3 >  1.0f ?  1.0f : s3 < -1.0f ? -1.0f : s3;

        /* 4-channel feature vector: [ch0, ch1, ch2_left, ch3_right] */
        float input_features[IMAI_DATA_IN_COUNT];
        input_features[0] = s0;
        input_features[1] = s1;
        input_features[2] = s2;
        input_features[3] = s3;

        result = IMAI_enqueue(input_features);
        CY_ASSERT(IMAI_RET_SUCCESS == result);

        best_label = 0;
        max_score  = -1000.0f;

        switch(IMAI_dequeue(label_scores))
        {
            case IMAI_RET_SUCCESS:
                for(int i = 0; i < IMAI_DATA_OUT_COUNT; i++)
                {
                    printf("label: %-11s: score: %.4f\r\n", label_text[i], label_scores[i]);
                    if(label_scores[i] > max_score)
                        { max_score = label_scores[i]; best_label = i; }
                }
                printf("\n\nOutput: %-10s\r\n",
                       max_score >= OUTPUT_THRESHOLD_SCORE ? label_text[best_label] : "");
                break;
            case IMAI_RET_NODATA: break;
            case IMAI_RET_ERROR:  CY_ASSERT(0); break;
        }
    }
    return result;
}
